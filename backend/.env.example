# Example DATABASE_URL for Supabase Postgres:
# postgres://<user>:<password>@<host>:5432/<database>
# For local dev using SQLite (default):
DATABASE_URL=sqlite:///./dev.db

# Firebase auth settings (path to service account JSON file or JSON content)
FIREBASE_CREDENTIALS=/path/to/firebase-service-account.json

# Comma-separated list of emails to seed as admin users on startup
INITIAL_ADMIN_EMAILS=admin@example.com

# Optionally set a server PORT
PORT=8000